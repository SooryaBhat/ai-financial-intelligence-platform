# ──────────────────────────────────────────────────────────────
# AI Financial Intelligence Platform — Backend Environment
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── JWT ───────────────────────────────────────────────────────
# Must match Supabase project JWT secret (Settings > API > JWT Secret)
JWT_SECRET=your-supabase-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# ── Application ───────────────────────────────────────────────
APP_NAME=AI Financial Intelligence Platform
APP_VERSION=1.0.0
APP_ENV=development          # development | staging | production
DEBUG=true

# ── Server ────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
LOG_FILE=logs/app.log        # Leave empty to log to stdout only
